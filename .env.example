# Gfilas sample configuration file
SECRET_KEY=troque-esta-chave-por-uma-nova

# Database path (relative to the project root)
PAINEL_DB_PATH=ultima_senha.db

# Defaults shown on the UI when values are missing
PAINEL_UNIDADE_PADRAO=UNIDADE
PAINEL_USUARIO_PADRAO=admin
PAINEL_FUSO_HORARIO=America/Sao_Paulo

# Optional overrides
# PAINEL_MAX_ULTIMAS=8
# PAINEL_VIDEO_URL=https://example.com/video.mp4
# PAINEL_VIDEO_MUTED=1
# PAINEL_YT_PLAYLIST_URL=https://www.youtube.com/playlist?list=PLxxx
# PAINEL_YT_MUTED=1

# Thermal printer on Windows (ESC/POS via win32print)
THERMAL_PRINTER_MODE=local
THERMAL_PRINTER_ENABLED=1
THERMAL_PRINTER_NAME=POS58 DRIVER (TESTADO)
THERMAL_PRINTER_ENCODING=cp850

# Remote print agent
# PRINT_AGENT_BASE_URL=https://white-glade-1234.fly.dev
# PRINT_AGENT_TOKEN=troque-por-um-token-longo
# PRINT_AGENT_POLL_INTERVAL=1.0
